<Window x:Class="JabInspector.App.CustomRepositoryTemplateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Custom Repository"
        Width="460"
        Height="250"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBrush}"
        FontFamily="Segoe UI">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock Text="Create custom object repository" FontWeight="Bold" FontSize="15"/>
      <TextBlock Text="Provide a logical repository name. You will choose the save location next."
                 Foreground="{StaticResource MutedBrush}"
                 TextWrapping="Wrap"
                 Margin="0,4,0,0"/>
    </StackPanel>

    <Grid Grid.Row="1" Margin="0,18,0,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <TextBlock Text="Repository name" FontWeight="SemiBold"/>
      <TextBox x:Name="RepositoryNameText" Grid.Row="1" Margin="0,6,0,0" MinHeight="32"/>
      <TextBlock Grid.Row="2" Text="Application alias (optional)" FontWeight="SemiBold" Margin="0,12,0,0"/>
      <TextBox x:Name="ApplicationAliasText" Grid.Row="3" Margin="0,6,0,0" MinHeight="32"/>
    </Grid>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="Cancel" Width="90" Click="Cancel_Click"/>
      <Button Content="Continue" Width="100" Style="{StaticResource PrimaryButton}" Margin="6,0,0,0" Click="Continue_Click"/>
    </StackPanel>
  </Grid>
</Window>
