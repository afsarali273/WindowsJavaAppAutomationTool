<Window x:Class="JabInspector.App.RecordingStudioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:JabInspector.App.Helpers"
        Title="Java Recorder Studio"
        Width="1120"
        Height="730"
        MinWidth="960"
        MinHeight="600"
        Background="#F1F5F9"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

    <!-- Color Palette -->
    <SolidColorBrush x:Key="BorderBrush" Color="#CBD5E1"/>
    <SolidColorBrush x:Key="MutedBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="InkBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TerminalBg" Color="#0F172A"/>
    <SolidColorBrush x:Key="TerminalFg" Color="#00E6FF"/>

    <!-- Reusable Styles -->
    <Style x:Key="SleekButton" TargetType="Button">
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="BorderBrush" Value="#CBD5E1"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="#0F172A"/>
      <Setter Property="Padding" Value="12,7"/>
      <Setter Property="MinHeight" Value="32"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F8FAFC"/>
                <Setter Property="BorderBrush" Value="#94A3B8"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#EFF6FF"/>
                <Setter Property="BorderBrush" Value="#3B82F6"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryHeaderButton" TargetType="Button" BasedOn="{StaticResource SleekButton}">
      <Setter Property="Background" Value="#3B82F6"/>
      <Setter Property="BorderBrush" Value="#2563EB"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="16"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#2563EB"/>
                <Setter Property="BorderBrush" Value="#1D4ED8"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#1D4ED8"/>
                <Setter Property="BorderBrush" Value="#1E40AF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="HeaderSuccessButton" TargetType="Button" BasedOn="{StaticResource SleekButton}">
      <Setter Property="Background" Value="#10B981"/>
      <Setter Property="BorderBrush" Value="#059669"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="16"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#059669"/>
                <Setter Property="BorderBrush" Value="#047857"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#047857"/>
                <Setter Property="BorderBrush" Value="#064E3B"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="HeaderDangerButton" TargetType="Button" BasedOn="{StaticResource SleekButton}">
      <Setter Property="Background" Value="#EF4444"/>
      <Setter Property="BorderBrush" Value="#DC2626"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="16"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#DC2626"/>
                <Setter Property="BorderBrush" Value="#B91C1C"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#B91C1C"/>
                <Setter Property="BorderBrush" Value="#991B1B"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="HeaderLightButton" TargetType="Button" BasedOn="{StaticResource SleekButton}">
      <Setter Property="Background" Value="#334155"/>
      <Setter Property="BorderBrush" Value="#475569"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="16"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#475569"/>
                <Setter Property="BorderBrush" Value="#64748B"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#1E293B"/>
                <Setter Property="BorderBrush" Value="#0F172A"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="HeaderIconButton" TargetType="Button" BasedOn="{StaticResource SleekButton}">
      <Setter Property="Width" Value="34"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="MinHeight" Value="34"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0,0,6,0"/>
      <Setter Property="Background" Value="#334155"/>
      <Setter Property="BorderBrush" Value="#475569"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="17"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#475569"/>
                <Setter Property="BorderBrush" Value="#64748B"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#1E293B"/>
                <Setter Property="BorderBrush" Value="#94A3B8"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="HeaderPrimaryIconButton" TargetType="Button" BasedOn="{StaticResource HeaderIconButton}">
      <Setter Property="Background" Value="#2563EB"/>
      <Setter Property="BorderBrush" Value="#3B82F6"/>
    </Style>

    <Style x:Key="HeaderSuccessIconButton" TargetType="Button" BasedOn="{StaticResource HeaderIconButton}">
      <Setter Property="Background" Value="#059669"/>
      <Setter Property="BorderBrush" Value="#10B981"/>
    </Style>

    <Style x:Key="HeaderDangerIconButton" TargetType="Button" BasedOn="{StaticResource HeaderIconButton}">
      <Setter Property="Background" Value="#DC2626"/>
      <Setter Property="BorderBrush" Value="#EF4444"/>
    </Style>

    <Style x:Key="ToolboxButton" TargetType="Button" BasedOn="{StaticResource SleekButton}">
      <Setter Property="Padding" Value="8"/>
      <Setter Property="Background" Value="#F8FAFC"/>
      <Setter Property="BorderBrush" Value="#E2E8F0"/>
      <Setter Property="Foreground" Value="#0F172A"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#E0F2FE"/>
                <Setter Property="BorderBrush" Value="#7DD3FC"/>
                <Setter Property="Foreground" Value="#0369A1"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#BAE6FD"/>
                <Setter Property="BorderBrush" Value="#38BDF8"/>
                <Setter Property="Foreground" Value="#0284C7"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PanelBorder" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="BorderBrush" Value="#E2E8F0"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="12"/>
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- Custom ListBoxItem Style for a Premium Feel -->
    <Style TargetType="ListBoxItem">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Margin" Value="0,2,0,2"/>
      <Setter Property="Padding" Value="4"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8"
                    SnapsToDevicePixels="True">
              <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F8FAFC"/>
                <Setter Property="BorderBrush" Value="#E2E8F0"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#EFF6FF"/>
                <Setter Property="BorderBrush" Value="#BFDBFE"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <!-- Row 0: Enterprise Sleek Header Bar -->
      <RowDefinition Height="Auto"/>
      <!-- Row 1: Left, Middle, Right workspaceColumns -->
      <RowDefinition Height="*"/>
      <!-- Row 2: Playback Output Terminal Console -->
      <RowDefinition Height="145"/>
    </Grid.RowDefinitions>

    <!-- Sleek Studio Header (Polished Deep Charcoal Navy) -->
    <Border Grid.Row="0" Background="#1E293B" BorderBrush="#0F172A" BorderThickness="0,0,0,1" Padding="14,10,14,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <!-- Logo Circle Pulsing-styled container -->
          <Border Width="36" Height="36" CornerRadius="18" Background="#334155" BorderBrush="#475569" BorderThickness="1" Margin="0,0,12,0">
            <Viewbox Width="20" Height="20">
              <Canvas Width="24" Height="24">
                <Ellipse Canvas.Left="5" Canvas.Top="5" Width="14" Height="14" Fill="#3B82F6"/>
                <Ellipse Canvas.Left="9" Canvas.Top="9" Width="6" Height="6" Fill="White"/>
              </Canvas>
            </Viewbox>
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="JAVA RECORDER STUDIO" FontSize="14" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="{Binding RecordingStatus}" Foreground="#94A3B8" FontSize="10.5" MaxWidth="420" TextTrimming="CharacterEllipsis"/>
          </StackPanel>
        </StackPanel>

        <!-- Dynamic Status chips inside header -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0,10,0">
          <Border Background="#3B82F6" CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
            <StackPanel Orientation="Horizontal">
              <Path Width="10" Height="10" Fill="White" Stretch="Uniform" Margin="0,0,5,0" Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10,10-4.48,10-10S17.52,2,12,2z M12,20c-4.41,0-8-3.59-8-8s3.59-8,8-8s8,3.59,8,8S16.41,20,12,20z"/>
              <TextBlock Text="{Binding RecordingBadgeText}" Foreground="White" FontWeight="SemiBold" FontSize="10.5"/>
            </StackPanel>
          </Border>
          <Border Background="#1E293B" BorderBrush="#475569" BorderThickness="1" CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
            <TextBlock Text="{Binding RecordingStepCount, StringFormat={}{0} captured steps}" Foreground="#F1F5F9" FontWeight="SemiBold" FontSize="10.5"/>
          </Border>
          <Border Background="#1E293B" BorderBrush="#475569" BorderThickness="1" CornerRadius="12" Padding="10,4">
            <TextBlock Text="{Binding RecordingObjectCount, StringFormat={}{0} objects saved}" Foreground="#F1F5F9" FontWeight="SemiBold" FontSize="10.5"/>
          </Border>
        </StackPanel>

        <!-- Compact command bar: icon-only controls with tooltips keep this fitting on smaller screens. -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <Button Click="NewSession_Click" Style="{StaticResource HeaderPrimaryIconButton}" ToolTip="New recording session">
            <Path Width="14" Height="14" Fill="White" Stretch="Uniform" Data="M12,4a8,8 0,1 0,0.01,0z M11,7h2v4h4v2h-4v4h-2v-4H7v-2h4z"/>
          </Button>
          <Button Click="TogglePause_Click" Style="{StaticResource HeaderIconButton}" ToolTip="{Binding RecordingPauseButtonText}">
            <Grid Width="14" Height="14">
              <Rectangle Width="4" Height="13" Fill="White" HorizontalAlignment="Left" RadiusX="1" RadiusY="1"/>
              <Rectangle Width="4" Height="13" Fill="White" HorizontalAlignment="Right" RadiusX="1" RadiusY="1"/>
            </Grid>
          </Button>
          <Button Click="StopSession_Click" Style="{StaticResource HeaderDangerIconButton}" ToolTip="Stop recording">
            <Rectangle Width="13" Height="13" RadiusX="2" RadiusY="2" Fill="White"/>
          </Button>
          <Button Click="Playback_Click" Style="{StaticResource HeaderSuccessIconButton}" ToolTip="Play recording">
            <Path Width="13" Height="13" Fill="White" Stretch="Uniform" Data="M8,5v14l11-7z"/>
          </Button>
          <Rectangle Width="1" Height="22" Fill="#475569" Margin="2,0,8,0"/>
          <Button Click="MoreActions_Click" Style="{StaticResource HeaderIconButton}" ToolTip="More recording project actions">
            <Button.ContextMenu>
              <ContextMenu>
                <MenuItem Header="Save project" Click="SaveProject_Click">
                  <MenuItem.Icon>
                    <Path Width="14" Height="14" Fill="#2563EB" Stretch="Uniform" Data="M17,3H5C3.9,3,3,3.9,3,5v14c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2V7z M12,19a3,3 0,1 1,0,-6a3,3 0,0 1,0,6z M15,9H5V5h10z"/>
                  </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Load project" Click="LoadProject_Click">
                  <MenuItem.Icon>
                    <Path Width="14" Height="14" Fill="#2563EB" Stretch="Uniform" Data="M20,6h-8l-2-2H4C2.9,4,2,4.9,2,6v12c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V8C22,6.9,21.1,6,20,6z M20,18H4V8h16z"/>
                  </MenuItem.Icon>
                </MenuItem>
              </ContextMenu>
            </Button.ContextMenu>
            <Path Width="14" Height="14" Fill="White" Stretch="Uniform" Data="M12,8a2,2 0,1 0,0.01,0z M12,14a2,2 0,1 0,0.01,0z M12,20a2,2 0,1 0,0.01,0z"/>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Row 1: Workspace Grid -->
    <Grid Grid.Row="1" Margin="10,12,10,8">
      <Grid.ColumnDefinitions>
        <!-- Column 0: Premium Object Repository Side-Panel -->
        <ColumnDefinition Width="315" MinWidth="260"/>
        <!-- Column 1: central Recorded Steps connected Timeline -->
        <ColumnDefinition Width="*" MinWidth="420"/>
        <!-- Column 2: Studio Automation Toolbox Side-panel -->
        <ColumnDefinition Width="290" MinWidth="240"/>
      </Grid.ColumnDefinitions>

      <!-- Panel 0: Object Repository (Left Pane) -->
      <Grid Grid.Column="0" Margin="0,0,10,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="1.3*"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Object List card -->
        <Border Grid.Row="0" Style="{StaticResource PanelBorder}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,10">
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="OBJECT REPOSITORY" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Saved unique identifier and properties mapping." Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="0,1,0,0"/>
              </StackPanel>
              <!-- Target Capture icon button in repository header -->
              <Button HorizontalAlignment="Right" Click="CaptureObject_Click" Padding="6" MinHeight="26" ToolTip="Capture highlighted active selection into local project map" Style="{StaticResource SleekButton}">
                <Path Width="11" Height="11" Fill="#2563EB" Stretch="Uniform" Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M12,20c-4.41,0-8-3.59-8-8s3.59-8,8-8s8,3.59,8,8S16.41,20,12,20z M12,11c-0.55,0-1,0.45-1,1s0.45,1,1,1s1-0.45,1-1S12.55,11,12,11z"/>
              </Button>
            </Grid>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding RepositoryEntries}"
                     SelectedItem="{Binding SelectedRepositoryEntry}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Padding="6,6,6,6" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <!-- Repository Icon Indicator -->
                      <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12" Background="#F0FDFA" BorderBrush="#5EEAD4" BorderThickness="1">
                        <Path Width="10" Height="10" Fill="#0D9488" Stretch="Uniform" Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10H7v-2h10v2zm0-4H7V7h10v2z"/>
                      </Border>
                      <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="11.5" Foreground="{StaticResource InkBrush}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Description, StringFormat=Desc: {0}}" Foreground="{StaticResource MutedBrush}" FontSize="9.5" TextTrimming="CharacterEllipsis" Visibility="{Binding Description, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}"/>
                        <TextBlock Text="{Binding Path}" Foreground="#94A3B8" FontFamily="Consolas" FontSize="8.5" TextTrimming="CharacterEllipsis"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>

        <!-- Divider line -->
        <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="Transparent" ResizeBehavior="PreviousAndNext"/>

        <!-- Repository item specifications/locator card -->
        <Border Grid.Row="2" Style="{StaticResource PanelBorder}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Margin="0,0,0,8">
              <TextBlock Text="REPOSITORY LOCATOR PREVIEW" Style="{StaticResource SectionTitle}"/>
              <TextBlock Text="JSON properties used to locate mapped objects." Foreground="{StaticResource MutedBrush}" FontSize="10"/>
            </StackPanel>
            <TextBox Grid.Row="1" Text="{Binding RecordingRepositoryPreview, Mode=OneWay}" IsReadOnly="True"
                     AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="10"
                     Background="#1E293B" Foreground="#38BDF8" BorderBrush="#334155" Padding="8"/>
          </Grid>
        </Border>
      </Grid>

      <!-- Panel 1: Connected Timeline (Center Pane) -->
      <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="0,0,10,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <Border Padding="4,0,4,12" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Margin="0,0,0,10">
            <Grid>
              <StackPanel>
                <TextBlock Text="RECORDED TIMELINE" Style="{StaticResource SectionTitle}" FontSize="12"/>
                <TextBlock Text="Wired sequence of operations captured and cataloged for semantic execution."
                           Foreground="{StaticResource MutedBrush}" FontSize="10.5" Margin="0,2,0,0"/>
              </StackPanel>
              <!-- Delete Trash button in central Timeline header -->
              <Button HorizontalAlignment="Right" Click="DeleteStep_Click" Padding="8,4" MinHeight="26" ToolTip="Delete selected timeline step" Style="{StaticResource SleekButton}">
                <StackPanel Orientation="Horizontal">
                  <Path Width="10" Height="10" Fill="#EF4444" Stretch="Uniform" Data="M6,19c0,1.1,0.9,2,2,2h8c1.1,0,2-0.9,2-2V7H6V19z M19,4h-3.5l-1-1h-5l-1,1H5v2h14V4z" VerticalAlignment="Center"/>
                  <TextBlock Text="Delete" Margin="5,0,0,0" FontSize="10.5" FontWeight="SemiBold" Foreground="#EF4444" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </Grid>
          </Border>

          <ListBox Grid.Row="1"
                   ItemsSource="{Binding RecordedSteps}"
                   SelectedItem="{Binding SelectedRecordedStep}"
                   BorderThickness="0"
                   Background="Transparent"
                   Padding="4,0,4,0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <!-- Timeline Node connector bar column -->
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>

                  <!-- Connection thread graphics -->
                  <Grid Grid.Column="0" HorizontalAlignment="Center">
                    <Rectangle Width="2" Fill="#E2E8F0" VerticalAlignment="Stretch" SnapsToDevicePixels="True"/>
                    <Border Width="26" Height="26" CornerRadius="13" Background="#EFF6FF" BorderBrush="#3B82F6" BorderThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Sequence}" Foreground="#2563EB" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                  </Grid>

                  <!-- Content card -->
                  <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12" Margin="8,2,4,2">
                    <Border.Effect>
                      <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.04" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>
                      <StackPanel>
                        <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource InkBrush}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ObjectDescription, StringFormat=Description: {0}}" Foreground="{StaticResource MutedBrush}" FontSize="10" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ObjectVirtualAccessibleName, StringFormat=JAWS: {0}}" Foreground="{StaticResource MutedBrush}" FontSize="10" TextWrapping="Wrap" Visibility="{Binding ObjectVirtualAccessibleName, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}"/>
                        <TextBlock Foreground="#94A3B8" FontSize="9.5" Margin="0,4,0,0">
                          <Run Text="{Binding CapturedAtUtc, StringFormat={}{0:HH:mm:ss}}"/>
                          <Run Text="  •  "/>
                          <Run Text="{Binding WindowTitle}"/>
                          <Run Text=" (depth "/>
                          <Run Text="{Binding ObjectDepth}"/>
                          <Run Text=")"/>
                        </TextBlock>
                      </StackPanel>
                      <!-- Action Kind Stamp badge -->
                      <Border Grid.Column="1" Background="#EFF6FF" BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="12" Padding="10,4" Margin="8,0,0,0" VerticalAlignment="Top">
                        <TextBlock Text="{Binding ActionKind}" Foreground="#2563EB" FontSize="10" FontWeight="Bold"/>
                      </Border>
                    </Grid>
                  </Border>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- Panel 2: Code Automation Toolbox (Right Pane) -->
      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="1.35*"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Studio controllers card -->
        <Border Grid.Row="0" Style="{StaticResource PanelBorder}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="130"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,10">
              <TextBlock Text="AUTOMATION TOOLBOX" Style="{StaticResource SectionTitle}"/>
              <TextBlock Text="Inject manual execution and assertions." Foreground="{StaticResource MutedBrush}" FontSize="10"/>
            </StackPanel>

            <!-- Click & Mouse Controllers -->
            <Grid Grid.Row="1">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <TextBlock Text="MOUSE &amp; STATE" FontSize="9.5" FontWeight="Bold" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
              <UniformGrid Grid.Row="1" Columns="2">
                <Button Click="Click_Click" Style="{StaticResource ToolboxButton}" ToolTip="Inject Click on active selection" Margin="0,0,4,4">
                  <StackPanel Orientation="Horizontal">
                    <Path Width="11" Height="11" Fill="#2563EB" Stretch="Uniform" Data="M11.5,14.5l-2.43-4.14l4.24-1.72L5.5,5l2.42,10.64l2.12-3.69L11.5,14.5z"/>
                    <TextBlock Text="Click" Margin="6,0,0,0" FontSize="11" FontWeight="SemiBold"/>
                  </StackPanel>
                </Button>
                <Button Click="DoubleClick_Click" Style="{StaticResource ToolboxButton}" ToolTip="Inject Double-Click on active selection" Margin="4,0,0,4">
                  <StackPanel Orientation="Horizontal">
                    <Path Width="11" Height="11" Fill="#2563EB" Stretch="Uniform" Data="M11.5,14.5l-2.43-4.14l4.24-1.72L5.5,5l2.42,10.64l2.12-3.69L11.5,14.5z M16.5,12l-1.5-.75V7h-3"/>
                    <TextBlock Text="DbClick" Margin="6,0,0,0" FontSize="11" FontWeight="SemiBold"/>
                  </StackPanel>
                </Button>
                <Button Click="Focus_Click" Style="{StaticResource ToolboxButton}" ToolTip="Target accessible component focus action" Margin="0,4,4,0">
                  <StackPanel Orientation="Horizontal">
                    <Path Width="11" Height="11" Fill="#0D9488" Stretch="Uniform" Data="M4,4h5V2H4C2.9,2,2,2.9,2,4v5h2V4z M20,2h-5v2h5v5h2V4C22,2.9,21.1,2,20,2z M12,8a4,4,0,1,0,4,4A4,4,0,0,0,12,8Z"/>
                    <TextBlock Text="Focus" Margin="6,0,0,0" FontSize="11" FontWeight="SemiBold"/>
                  </StackPanel>
                </Button>
                <Button Click="GetText_Click" Style="{StaticResource ToolboxButton}" ToolTip="Assert &amp; extract values" Margin="4,4,0,0">
                  <StackPanel Orientation="Horizontal">
                    <Path Width="11" Height="11" Fill="#0D9488" Stretch="Uniform" Data="M14,2H6C4.9,2,4,2.9,4,4v16c0,1.1,0.89,2,1.99,2H18c1.1,0,2-0.9,2-2V8L14,2z M12,18H8v-2h4V18z"/>
                    <TextBlock Text="Get Text" Margin="6,0,0,0" FontSize="11" FontWeight="SemiBold"/>
                  </StackPanel>
                </Button>
              </UniformGrid>
            </Grid>

            <!-- Text Writing & Keyboard Controllers -->
            <Grid Grid.Row="2" Margin="0,10,0,0">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock Text="TEXT INPUT &amp; ENTRY" FontSize="9.5" FontWeight="Bold" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
              <TextBox x:Name="RecorderTextInput" Grid.Row="1"
                       Margin="0,0,0,8"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Auto"
                       Padding="8"
                       BorderBrush="#CBD5E1"
                       Background="#F8FAFC"
                       HorizontalContentAlignment="Stretch"
                       VerticalContentAlignment="Top"
                       ToolTip="Write text script to execute Set Text or keystrokes typing."/>
              <UniformGrid Grid.Row="2" Columns="2">
                <Button Click="SetText_Click" Style="{StaticResource ToolboxButton}" ToolTip="Directly sets text context on input component" Margin="0,0,4,0">
                  <StackPanel Orientation="Horizontal">
                    <Path Width="11" Height="11" Fill="#7C3AED" Stretch="Uniform" Data="M21,11H3V9h18V11z M21,15H3v-2h18V15z M21,7H3V5h18V7z"/>
                    <TextBlock Text="Set Text" Margin="6,0,0,0" FontSize="11" FontWeight="SemiBold"/>
                  </StackPanel>
                </Button>
                <Button Click="TypeText_Click" Style="{StaticResource ToolboxButton}" ToolTip="Triggers standard virtual key sequence typing assertion" Margin="4,0,0,0">
                  <StackPanel Orientation="Horizontal">
                    <Path Width="11" Height="11" Fill="#7C3AED" Stretch="Uniform" Data="M20,5H4C2.9,5,2,5.9,2,7v10c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V7C22,5.9,21.1,5,20,5z M20,17H4V7h16V17z M5,9h2v2H5V9z"/>
                    <TextBlock Text="Type" Margin="6,0,0,0" FontSize="11" FontWeight="SemiBold"/>
                  </StackPanel>
                </Button>
              </UniformGrid>
            </Grid>
          </Grid>
        </Border>

        <!-- Divider line -->
        <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="Transparent" ResizeBehavior="PreviousAndNext"/>

        <!-- Selected step specifications card -->
        <Border Grid.Row="2" Style="{StaticResource PanelBorder}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Margin="0,0,0,8">
              <TextBlock Text="SELECTED TIMELINE STEP LOCATOR" Style="{StaticResource SectionTitle}"/>
              <TextBlock Text="Properties mapping for the selected playback step." Foreground="{StaticResource MutedBrush}" FontSize="10"/>
            </StackPanel>
            <TextBox Grid.Row="1" Text="{Binding RecordingStepPreview, Mode=OneWay}" IsReadOnly="True"
                     AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="10"
                     Background="#1E293B" Foreground="#38BDF8" BorderBrush="#334155" Padding="8"/>
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <!-- Row 2: Live Playback Terminal console -->
    <Border Grid.Row="2" Background="{StaticResource TerminalBg}" BorderThickness="0,1,0,0" BorderBrush="#111827">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Terminal header -->
        <Border Background="#1E293B" Padding="14,6,14,6" BorderThickness="0,0,0,1" BorderBrush="#0F172A">
          <Grid>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <!-- Terminal icon of command prompt / chevron -->
              <Path Width="11" Height="11" Fill="#00E6FF" Stretch="Uniform" Data="M8.59,16.59L13.17,12L8.59,7.41L10,6l6,6l-6,6L8.59,16.59z M18,17v-2h-6v2H18z" VerticalAlignment="Center"/>
              <TextBlock Text="LIVE PLAYBACK CONSOLE" Foreground="White" FontWeight="Bold" FontSize="10.5" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Streaming log of JAB lookups, transitions, and locator evaluations." Foreground="#94A3B8" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
          </Grid>
        </Border>

        <!-- Terminal console text box -->
        <TextBox Grid.Row="1" Text="{Binding PlaybackOutput, Mode=OneWay}" IsReadOnly="True"
                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="11" Background="{StaticResource TerminalBg}"
                 Foreground="{StaticResource TerminalFg}" BorderThickness="0" Padding="12,8,12,8"
                 ScrollViewer.CanContentScroll="True" SelectionBrush="#22D3EE"/>
      </Grid>
    </Border>
  </Grid>
</Window>
