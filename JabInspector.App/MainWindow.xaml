<Window x:Class="JabInspector.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:model="clr-namespace:JabInspector.Core.Models;assembly=JabInspector.Core"
        xmlns:viewModel="clr-namespace:JabInspector.App.ViewModels"
        xmlns:winmodel="clr-namespace:WinInspector.Core.Models;assembly=WinInspector.Core"
        Title="Java Access Bridge Inspector"
        Width="980"
        Height="660"
        MinWidth="820"
        MinHeight="540"
        Background="{StaticResource PageBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="Manual">
  <Window.Resources>
    <Style x:Key="PanelBorder" TargetType="Border">
      <Setter Property="Background" Value="White"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>
    <Style x:Key="ToolButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Width" Value="34"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0,0,4,0"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style x:Key="ToolPrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolButton}">
      <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
    </Style>
    <Style x:Key="SectionTitle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
      <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>
    <Style x:Key="PropertyLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
      <Setter Property="Margin" Value="0,4"/>
      <Setter Property="FontSize" Value="10.5"/>
    </Style>
    <Style x:Key="PropertyValue" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
      <Setter Property="Margin" Value="0,4"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="FontSize" Value="10.5"/>
    </Style>

    <DataTemplate DataType="{x:Type viewModel:JavaWindowViewModel}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="30"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Width="24" Height="24" CornerRadius="6" Background="#E9F4ED" VerticalAlignment="Top">
          <TextBlock Text="J" Foreground="#1F7A50" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
        </Border>
        <StackPanel Grid.Column="1">
          <TextBlock Text="{Binding Model.Title, Mode=OneWay}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" FontSize="12"/>
          <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" FontFamily="Consolas" FontSize="9.5">
            <Run Text="{Binding Model.HwndDisplay, Mode=OneWay}"/>
            <Run Text="  ·  VM "/>
            <Run Text="{Binding Model.VmId, Mode=OneWay}"/>
          </TextBlock>
          <TextBlock Text="{Binding Model.ClassName, Mode=OneWay}" Foreground="#8A96A7" FontSize="9.5" TextTrimming="CharacterEllipsis"/>
        </StackPanel>
      </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModel:WindowsWindowViewModel}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="30"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Width="24" Height="24" CornerRadius="6" Background="#EEF5FA" VerticalAlignment="Top">
          <TextBlock Text="W" Foreground="#1F5E8C" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
        </Border>
        <StackPanel Grid.Column="1">
          <DockPanel LastChildFill="True">
            <Border DockPanel.Dock="Right"
                    Visibility="{Binding ElevationBadgeVisibility}"
                    Background="#FEE2E2"
                    BorderBrush="#FCA5A5"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="6,1"
                    Margin="6,0,0,0">
              <TextBlock Text="{Binding ElevationBadge}" Foreground="#B42318" FontSize="9" FontWeight="SemiBold"/>
            </Border>
            <TextBlock Text="{Binding Model.DisplayName, Mode=OneWay}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" FontSize="12"/>
          </DockPanel>
          <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" FontFamily="Consolas" FontSize="9.5">
            <Run Text="{Binding Model.HwndDisplay, Mode=OneWay}"/>
            <Run Text="  ·  PID "/>
            <Run Text="{Binding Model.ProcessId, Mode=OneWay}"/>
          </TextBlock>
          <TextBlock Foreground="#8A96A7" FontSize="9.5" TextTrimming="CharacterEllipsis">
            <Run Text="{Binding Model.ClassName, Mode=OneWay}"/>
            <Run Text="  ·  "/>
            <Run Text="{Binding Model.ApplicationKind, Mode=OneWay}"/>
          </TextBlock>
        </StackPanel>
      </Grid>
    </DataTemplate>

    <HierarchicalDataTemplate DataType="{x:Type model:AccessibleNode}" ItemsSource="{Binding Children}">
      <StackPanel Orientation="Horizontal" Margin="0,1">
        <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="3" Padding="4,1" Margin="0,0,5,0">
          <TextBlock Text="{Binding Role}" Foreground="{StaticResource AccentBrush}" FontSize="9.5" FontWeight="SemiBold"/>
        </Border>
        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="10.5">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Text" Value="{Binding Name}"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding Name}" Value="">
                  <Setter Property="Text" Value="(no name)"/>
                  <Setter Property="Foreground" Value="#93A1B2"/>
                  <Setter Property="FontStyle" Value="Italic"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </StackPanel>
    </HierarchicalDataTemplate>

    <HierarchicalDataTemplate DataType="{x:Type winmodel:WindowsAutomationNode}" ItemsSource="{Binding Children}">
      <StackPanel Orientation="Horizontal" Margin="0,1">
        <Border Background="#EEF5FA" CornerRadius="3" Padding="4,1" Margin="0,0,5,0">
          <TextBlock Text="{Binding Role}" Foreground="#1F5E8C" FontSize="9.5" FontWeight="SemiBold"/>
        </Border>
        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" FontSize="10.5" TextTrimming="CharacterEllipsis"/>
      </StackPanel>
    </HierarchicalDataTemplate>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition x:Name="DiagnosticsRow" Height="108"/>
      <RowDefinition Height="24"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8,6">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Border Width="26" Height="26" CornerRadius="5" Background="{StaticResource AccentBrush}">
            <TextBlock Text="J" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
          </Border>
          <StackPanel Margin="7,0,0,0">
            <TextBlock Text="{Binding ShellTitle}" FontSize="13" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding HeaderSubtitle}" FontSize="9.5" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" MaxWidth="245"/>
          </StackPanel>
        </StackPanel>

        <Border Grid.Column="2"
                HorizontalAlignment="Center"
                Background="#F9FBFC"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="5,4">
          <WrapPanel VerticalAlignment="Center" ItemHeight="28">
            <ComboBox Width="92"
                      SelectedItem="{Binding SelectedMode}"
                      ItemsSource="{Binding AvailableModes}"
                      Margin="0,0,5,0"
                      FontSize="11"
                      VerticalContentAlignment="Center"/>
            <Button Command="{Binding RefreshWindowsCommand}" Style="{StaticResource ToolButton}" ToolTip="{Binding RefreshButtonLabel}">
              <Viewbox Width="16" Height="16">
                <Path Fill="#0F766E" Stretch="Uniform" Data="M12,4A8,8 0 0 1 19.4,9H16.8A5.5,5.5 0 1 0 17.1,13H19.2A8,8 0 1 1 12,4M18,3V7H14"/>
              </Viewbox>
            </Button>
            <Button Name="PickerButton" PreviewMouseLeftButtonDown="PickerButton_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="PickerButton_PreviewMouseLeftButtonUp" Style="{StaticResource ToolButton}" ToolTip="Drag to pick and inspect an element from the target application">
              <Viewbox Width="16" Height="16">
                <Path Fill="#C2410C" Stretch="Uniform" Data="M10,2A1,1 0 0 1 11,3V9H17A1,1 0 0 1 17,11H11V17A1,1 0 0 1 9,17V11H3A1,1 0 0 1 3,9H9V3A1,1 0 0 1 10,2M19.7,19.7L15.8,15.8"/>
              </Viewbox>
            </Button>
            <Button Click="Highlight_Click" Style="{StaticResource ToolButton}" ToolTip="Highlight selected element">
              <Viewbox Width="16" Height="16">
                <Path Fill="#DC2626" Stretch="Uniform" Data="M12,3A9,9 0 1 0 21,12A9,9 0 0 0 12,3M12,6A6,6 0 1 1 6,12A6,6 0 0 1 12,6M11,1H13V4H11M11,20H13V23H11M1,11H4V13H1M20,11H23V13H20"/>
              </Viewbox>
            </Button>
            <Button Command="{Binding CopyLocatorCommand}" Style="{StaticResource ToolButton}" ToolTip="Copy locator JSON">
              <Viewbox Width="16" Height="16">
                <Path Fill="#4F46E5" Stretch="Uniform" Data="M16,1H6A2,2 0 0 0 4,3V15H6V3H16M19,5H10A2,2 0 0 0 8,7V21A2,2 0 0 0 10,23H19A2,2 0 0 0 21,21V7A2,2 0 0 0 19,5Z"/>
              </Viewbox>
            </Button>
            <Button Click="Export_Click" Style="{StaticResource ToolButton}" ToolTip="Export tree JSON">
              <Viewbox Width="16" Height="16">
                <Path Fill="#0369A1" Stretch="Uniform" Data="M5,20H19V22H5M11,3H13V12H16L12,17L8,12H11V3Z"/>
              </Viewbox>
            </Button>
            <Button Click="OpenObjectRepository_Click" Style="{StaticResource ToolButton}" ToolTip="Open object repository manager">
              <Viewbox Width="16" Height="16">
                <Path Fill="#15803D" Stretch="Uniform" Data="M4,5A2,2 0 0 1 6,3H10L12,5H18A2,2 0 0 1 20,7V18A2,2 0 0 1 18,20H6A2,2 0 0 1 4,18V5M7,9H17V11H7M7,13H14V15H7"/>
              </Viewbox>
            </Button>
          </WrapPanel>
        </Border>

        <StackPanel Grid.Column="3" Orientation="Horizontal">
          <Button Click="Settings_Click" Style="{StaticResource ToolButton}" ToolTip="Settings">
            <Viewbox Width="16" Height="16">
              <Path Fill="#475569" Stretch="Uniform" Data="M19.4,13A7.9,7.9 0 0 0 19.5,12A7.9,7.9 0 0 0 19.4,11L21.5,9.4A0.5,0.5 0 0 0 21.6,8.7L19.6,5.3A0.5,0.5 0 0 0 19,5.1L16.5,6.1A7.6,7.6 0 0 0 14.7,5L14.3,2.3A0.5,0.5 0 0 0 13.8,2H10.2A0.5,0.5 0 0 0 9.7,2.3L9.3,5A7.6,7.6 0 0 0 7.5,6.1L5,5.1A0.5,0.5 0 0 0 4.4,5.3L2.4,8.7A0.5,0.5 0 0 0 2.5,9.4L4.6,11A7.9,7.9 0 0 0 4.5,12A7.9,7.9 0 0 0 4.6,13L2.5,14.6A0.5,0.5 0 0 0 2.4,15.3L4.4,18.7A0.5,0.5 0 0 0 5,18.9L7.5,17.9A7.6,7.6 0 0 0 9.3,19L9.7,21.7A0.5,0.5 0 0 0 10.2,22H13.8A0.5,0.5 0 0 0 14.3,21.7L14.7,19A7.6,7.6 0 0 0 16.5,17.9L19,18.9A0.5,0.5 0 0 0 19.6,18.7L21.6,15.3A0.5,0.5 0 0 0 21.5,14.6L19.4,13M12,15.2A3.2,3.2 0 1 1 15.2,12A3.2,3.2 0 0 1 12,15.2Z"/>
            </Viewbox>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <TabControl x:Name="WorkspaceTabs" Grid.Row="1" Margin="6,6,6,4" BorderThickness="0" Background="Transparent" SelectionChanged="WorkspaceTabs_SelectionChanged">
      <TabItem x:Name="InspectorWorkspaceTab" Header="  INSPECTOR  ">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="300"/>
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="280"/>
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="*" MinWidth="260"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <Border Padding="8,6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
              <TextBlock Style="{StaticResource SectionTitle}" Text="{Binding WindowPaneTitle}" VerticalAlignment="Center"/>
              <Border HorizontalAlignment="Right" Background="{StaticResource AccentSoftBrush}" CornerRadius="8" Padding="5,1">
                <TextBlock Text="{Binding WindowItemCount, StringFormat={}{0}}" Foreground="{StaticResource AccentBrush}" FontSize="9" FontWeight="SemiBold"/>
              </Border>
            </Grid>
          </Border>

          <ListBox Grid.Row="1"
                   ItemsSource="{Binding CurrentWindowItems}"
                   SelectedItem="{Binding SelectedWindowItem}"
                   BorderThickness="0"
                   Background="Transparent"
                   Padding="4"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                      <Border x:Name="Item"
                              Background="{TemplateBinding Background}"
                              BorderBrush="#E3E8EF"
                              BorderThickness="1"
                              CornerRadius="5"
                              Padding="6">
                        <ContentPresenter/>
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="Item" Property="Background" Value="#F7FAFD"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                          <Setter TargetName="Item" Property="Background" Value="#EEF5FA"/>
                          <Setter TargetName="Item" Property="BorderBrush" Value="#8FB1C9"/>
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </ListBox.ItemContainerStyle>
          </ListBox>

          <Border Grid.Row="2" Margin="5" Padding="6" CornerRadius="5" Background="#FFF9EC">
            <TextBlock Text="{Binding WindowPaneHint}" TextWrapping="Wrap" Foreground="#8A6522" FontSize="9.5"/>
          </Border>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1" Width="6" Background="Transparent" HorizontalAlignment="Stretch"/>

      <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Border Padding="8,6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
              <TextBlock Style="{StaticResource SectionTitle}" Text="ACCESSIBILITY HIERARCHY"/>
              <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource MutedBrush}" FontSize="10.5" Text="role · accessible name"/>
            </Grid>
          </Border>
          <Grid Grid.Row="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Padding="6" Margin="6,6,6,0" Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" Visibility="{Binding WindowsSelectionVisibility}">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TabControl SelectedValue="{Binding SelectedWindowsInspectionView}"
                            SelectedValuePath="Tag"
                            BorderThickness="0"
                            Background="Transparent">
                  <TabItem Header="AUTO" Tag="{x:Static winmodel:WindowsInspectionView.Routed}"/>
                  <TabItem Header="WIN32" Tag="{x:Static winmodel:WindowsInspectionView.Win32}"/>
                  <TabItem Header="MSAA" Tag="{x:Static winmodel:WindowsInspectionView.Msaa}"/>
                  <TabItem Header="UIA RAW" Tag="{x:Static winmodel:WindowsInspectionView.UiaRaw}"/>
                  <TabItem Header="UIA CTRL" Tag="{x:Static winmodel:WindowsInspectionView.UiaControl}"/>
                  <TabItem Header="UIA CONTENT" Tag="{x:Static winmodel:WindowsInspectionView.UiaContent}"/>
                </TabControl>
                <TextBlock Grid.Row="1"
                           Margin="2,4,2,0"
                           Foreground="#667085"
                           FontSize="10.5"
                           Text="{Binding WindowsInspectionHint}"
                           TextWrapping="Wrap"/>
                <TextBlock Grid.Row="2"
                           Margin="2,4,2,0"
                           Foreground="#8A6522"
                           FontSize="10"
                           Text="{Binding WindowsPrivilegeSummary}"
                           TextWrapping="Wrap"/>
              </Grid>
            </Border>
            <Border Grid.Row="1"
                    Margin="6,6,6,0"
                    Padding="8,6"
                    CornerRadius="5"
                    Background="#FFF4E8"
                    BorderBrush="#F7B267"
                    BorderThickness="1"
                    Visibility="{Binding WindowsPrivilegeWarningVisibility}">
              <TextBlock Text="{Binding SelectedWindowsPrivilegeWarning}" TextWrapping="Wrap" Foreground="#9A5B13" FontSize="10.5"/>
            </Border>
            <TreeView x:Name="AccessibilityTree"
                      Grid.Row="2"
                      ItemsSource="{Binding CurrentTreeItems}"
                      SelectedItemChanged="Tree_SelectedItemChanged"
                      PreviewMouseLeftButtonUp="AccessibilityTree_PreviewMouseLeftButtonUp"
                      BorderThickness="0"
                      Background="Transparent"
                      Padding="6"
                      FontSize="10.5"
                      VirtualizingPanel.IsVirtualizing="False"/>
          </Grid>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="3" Width="6" Background="Transparent" HorizontalAlignment="Stretch"/>

      <Border Grid.Column="4" Style="{StaticResource PanelBorder}">
        <TabControl x:Name="DetailsTabs" BorderThickness="0" Background="Transparent" SelectionChanged="DetailsTabs_SelectionChanged">
          <TabItem x:Name="PropertiesTab" Header="  PROPERTIES  ">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="8">
                <Border Background="#F4F8FB" CornerRadius="5" Padding="7" Margin="0,0,0,8">
                  <StackPanel>
                    <TextBlock Text="SELECTED ELEMENT" Foreground="{StaticResource AccentBrush}" FontSize="9" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SelectedDisplayName}" FontWeight="SemiBold" FontSize="11.5" Margin="0,3,0,0" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>

                <Border Background="#F4F8FB" CornerRadius="5" Padding="7" Margin="0,0,0,8" Visibility="{Binding JavaSelectionVisibility}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                      <TextBlock Text="OBJECT REPOSITORY" Foreground="{StaticResource AccentBrush}" FontSize="9" FontWeight="Bold"/>
                      <TextBlock Text="Save this inspected element as a reusable repository object." Foreground="#37536B" FontSize="10.5" TextWrapping="Wrap" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Click="AddPropertySelectionToRepository_Click" Style="{StaticResource PrimaryButton}" Content="+ Add object" VerticalAlignment="Center" Margin="8,0,0,0"/>
                  </Grid>
                </Border>

                <TextBlock Style="{StaticResource SectionTitle}" Text="IDENTITY" Margin="0,0,0,5"/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="88"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                  </Grid.RowDefinitions>
                  <TextBlock Style="{StaticResource PropertyLabel}" Text="Name"/>
                  <TextBlock Grid.Column="1" Style="{StaticResource PropertyValue}" Text="{Binding PropertyNameValue}"/>
                  <TextBlock Grid.Row="1" Style="{StaticResource PropertyLabel}" Text="Description"/>
                  <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource PropertyValue}" Text="{Binding PropertyDescriptionValue}"/>
                  <TextBlock Grid.Row="2" Style="{StaticResource PropertyLabel}" Text="Role"/>
                  <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource PropertyValue}" Text="{Binding PropertyRoleValue}"/>
                  <TextBlock Grid.Row="3" Style="{StaticResource PropertyLabel}" Text="Role / backend"/>
                  <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource PropertyValue}" Text="{Binding PropertyRoleSecondaryValue}"/>
                  <TextBlock Grid.Row="4" Style="{StaticResource PropertyLabel}" Text="States / class"/>
                  <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource PropertyValue}" Text="{Binding PropertyStatesValue}"/>
                  <TextBlock Grid.Row="5" Style="{StaticResource PropertyLabel}" Text="States / id"/>
                  <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource PropertyValue}" Text="{Binding PropertyStatesSecondaryValue}"/>
                </Grid>

                <Separator Margin="0,7" Background="{StaticResource BorderBrush}"/>
                <TextBlock Style="{StaticResource SectionTitle}" Text="GEOMETRY AND TREE" Margin="0,0,0,5"/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="88"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                  </Grid.RowDefinitions>
                  <TextBlock Style="{StaticResource PropertyLabel}" Text="Bounds"/>
                  <TextBlock Grid.Column="1" Style="{StaticResource PropertyValue}" FontFamily="Consolas" Text="{Binding PropertyBoundsValue}"/>
                  <TextBlock Grid.Row="1" Style="{StaticResource PropertyLabel}" Text="Index in parent"/>
                  <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource PropertyValue}" Text="{Binding PropertyIndexValue}"/>
                  <TextBlock Grid.Row="2" Style="{StaticResource PropertyLabel}" Text="Children"/>
                  <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource PropertyValue}" Text="{Binding PropertyChildrenValue}"/>
                  <TextBlock Grid.Row="3" Style="{StaticResource PropertyLabel}" Text="Raw IDs"/>
                  <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource PropertyValue}" FontFamily="Consolas" Text="{Binding PropertyRawIdsValue}"/>
                </Grid>

                <StackPanel Visibility="{Binding WindowsSelectionVisibility}">
                  <Separator Margin="0,7" Background="{StaticResource BorderBrush}"/>
                  <TextBlock Style="{StaticResource SectionTitle}" Text="WINDOWS EVIDENCE" Margin="0,0,0,5"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="88"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition/>
                      <RowDefinition/>
                      <RowDefinition/>
                      <RowDefinition/>
                      <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource PropertyLabel}" Text="Evidence"/>
                    <TextBlock Grid.Column="1" Style="{StaticResource PropertyValue}" Text="{Binding WindowsEvidenceSummary}" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="1" Style="{StaticResource PropertyLabel}" Text="Locators"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource PropertyValue}" FontFamily="Consolas" Text="{Binding WindowsLocatorCandidatesSummary}" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="2" Style="{StaticResource PropertyLabel}" Text="Metadata"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource PropertyValue}" FontFamily="Consolas" Text="{Binding WindowsMetadataSummary}" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="3" Style="{StaticResource PropertyLabel}" Text="ActiveX"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource PropertyValue}" FontFamily="Consolas" Text="{Binding WindowsActiveXSummary}" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="4" Style="{StaticResource PropertyLabel}" Text="AX details"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource PropertyValue}" FontFamily="Consolas" Text="{Binding WindowsActiveXDetails}" TextWrapping="Wrap"/>
                  </Grid>

                  <TextBlock Style="{StaticResource SectionTitle}" Text="LOCATOR CANDIDATES" Margin="0,10,0,5"/>
                  <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Background="#FBFCFE">
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="140"/>
                        <RowDefinition Height="Auto"/>
                      </Grid.RowDefinitions>
                      <ListView ItemsSource="{Binding WindowsLocatorCandidates}"
                                SelectedItem="{Binding SelectedWindowsLocatorCandidate}"
                                BorderThickness="0"
                                Background="Transparent"
                                Margin="0"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.View>
                          <GridView AllowsColumnReorder="False">
                            <GridViewColumn Header="P" Width="32" DisplayMemberBinding="{Binding Priority}"/>
                            <GridViewColumn Header="Type" Width="92" DisplayMemberBinding="{Binding Type}"/>
                            <GridViewColumn Header="Score" Width="46" DisplayMemberBinding="{Binding Score}"/>
                            <GridViewColumn Header="Conf" Width="48" DisplayMemberBinding="{Binding Confidence, StringFormat={}{0:0.00}}"/>
                            <GridViewColumn Header="Value" Width="300" DisplayMemberBinding="{Binding Value}"/>
                          </GridView>
                        </ListView.View>
                      </ListView>
                      <TextBox Grid.Row="1"
                               Margin="8"
                               Text="{Binding SelectedWindowsLocatorCandidateDetails, Mode=OneWay}"
                               IsReadOnly="True"
                               AcceptsReturn="True"
                               TextWrapping="NoWrap"
                               VerticalScrollBarVisibility="Auto"
                               HorizontalScrollBarVisibility="Auto"
                               FontFamily="Consolas"
                               FontSize="10"
                               Background="#F7F8FA"
                               BorderBrush="{StaticResource BorderBrush}"
                               Padding="8"
                               MinHeight="92"/>
                    </Grid>
                  </Border>
                </StackPanel>

                <StackPanel Visibility="{Binding JavaSelectionVisibility}">
                  <Separator Margin="0,7" Background="{StaticResource BorderBrush}"/>
                  <TextBlock Style="{StaticResource SectionTitle}" Text="ACCESSIBLE INTERFACES" Margin="0,0,0,5"/>
                  <WrapPanel>
                    <CheckBox Content="Component" IsChecked="{Binding SelectedNode.AccessibleComponent}" IsHitTestVisible="False" Margin="0,0,8,4" FontSize="10"/>
                    <CheckBox Content="Action" IsChecked="{Binding SelectedNode.AccessibleAction}" IsHitTestVisible="False" Margin="0,0,8,4" FontSize="10"/>
                    <CheckBox Content="Selection" IsChecked="{Binding SelectedNode.AccessibleSelection}" IsHitTestVisible="False" Margin="0,0,8,4" FontSize="10"/>
                    <CheckBox Content="Text" IsChecked="{Binding SelectedNode.AccessibleText}" IsHitTestVisible="False" Margin="0,0,8,4" FontSize="10"/>
                    <CheckBox Content="Value" IsChecked="{Binding SelectedNode.AccessibleValue}" IsHitTestVisible="False" Margin="0,0,8,4" FontSize="10"/>
                    <CheckBox Content="Table" IsChecked="{Binding SelectedNode.AccessibleTable}" IsHitTestVisible="False" Margin="0,0,8,4" FontSize="10"/>
                    <CheckBox Content="Interfaces" IsChecked="{Binding SelectedNode.AccessibleInterfaces}" IsHitTestVisible="False" Margin="0,0,8,4" FontSize="10"/>
                  </WrapPanel>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="  LOCATOR JSON  ">
            <Grid Margin="8">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock Text="Generated from semantics and hierarchy, not coordinates alone." Foreground="{StaticResource MutedBrush}" FontSize="9.5" TextWrapping="Wrap" Margin="2,0,2,5"/>
              <TextBox Grid.Row="1"
                       Text="{Binding LocatorPreview, Mode=OneWay}"
                       IsReadOnly="True"
                       AcceptsReturn="True"
                       TextWrapping="NoWrap"
                       VerticalScrollBarVisibility="Auto"
                       HorizontalScrollBarVisibility="Auto"
                       FontFamily="Consolas"
                       FontSize="11"
                       Background="#16202C"
                       Foreground="#E7ECF3"
                       BorderThickness="0"
                       Padding="10"/>
              <Button Grid.Row="2" Command="{Binding CopyLocatorCommand}" Style="{StaticResource PrimaryButton}" Margin="0,8,0,0" Content="Copy locator JSON"/>
            </Grid>
          </TabItem>

          <TabItem Header="  WINDOWS SOURCES  " Visibility="{Binding WindowsSelectionVisibility}">
            <Grid Margin="8">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <TextBlock Text="Backend-aware evidence for the selected Windows element. Use this to compare projected locators, raw node data, and point inspection results." Foreground="{StaticResource MutedBrush}" FontSize="9.5" TextWrapping="Wrap" Margin="2,0,2,6"/>
              <TabControl Grid.Row="1" BorderThickness="0" Background="Transparent">
                <TabItem Header="  PROJECTED  ">
                  <TextBox Margin="0,6,0,0"
                           Text="{Binding WindowsProjectedSourcePreview, Mode=OneWay}"
                           IsReadOnly="True"
                           AcceptsReturn="True"
                           TextWrapping="NoWrap"
                           VerticalScrollBarVisibility="Auto"
                           HorizontalScrollBarVisibility="Auto"
                           FontFamily="Consolas"
                           FontSize="10.5"
                           Background="#16202C"
                           Foreground="#E7ECF3"
                           BorderThickness="0"
                           Padding="10"/>
                </TabItem>
                <TabItem Header="  RAW NODE  ">
                  <TextBox Margin="0,6,0,0"
                           Text="{Binding WindowsRawSourcePreview, Mode=OneWay}"
                           IsReadOnly="True"
                           AcceptsReturn="True"
                           TextWrapping="NoWrap"
                           VerticalScrollBarVisibility="Auto"
                           HorizontalScrollBarVisibility="Auto"
                           FontFamily="Consolas"
                           FontSize="10.5"
                           Background="#16202C"
                           Foreground="#E7ECF3"
                           BorderThickness="0"
                           Padding="10"/>
                </TabItem>
                <TabItem Header="  POINT PROBE  ">
                  <TextBox Margin="0,6,0,0"
                           Text="{Binding WindowsPointProbePreview, Mode=OneWay}"
                           IsReadOnly="True"
                           AcceptsReturn="True"
                           TextWrapping="NoWrap"
                           VerticalScrollBarVisibility="Auto"
                           HorizontalScrollBarVisibility="Auto"
                           FontFamily="Consolas"
                           FontSize="10.5"
                           Background="#16202C"
                           Foreground="#E7ECF3"
                           BorderThickness="0"
                           Padding="10"/>
                </TabItem>
              </TabControl>
            </Grid>
          </TabItem>

          <TabItem Header="  AUTOMATION  ">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="14">
                <Border Background="#FFF4E8" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                  <TextBlock Text="Actions run against the current backend. In Java mode, these same actions can also be captured into a repository-backed recording session for later playback." Foreground="#9A5B13" FontSize="10.5" TextWrapping="Wrap"/>
                </Border>
                <TextBlock Style="{StaticResource SectionTitle}" Text="TARGET"/>
                <TextBlock Text="{Binding SelectedDisplayName}" FontWeight="SemiBold" Margin="0,4,0,2" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding SupportedActions}" Foreground="{StaticResource MutedBrush}" FontSize="10.5" TextWrapping="Wrap" Margin="0,0,0,10"/>
                <UniformGrid Columns="3" Margin="0,0,0,10">
                  <Button Click="FocusAction_Click" Content="Focus"/>
                  <Button Click="ClickAction_Click" Content="Click"/>
                  <Button Click="DoubleClickAction_Click" Content="Double-click" Margin="0"/>
                </UniformGrid>
                <TextBlock Style="{StaticResource SectionTitle}" Text="TEXT INPUT" Margin="0,0,0,5"/>
                <TextBox x:Name="AutomationInput" AcceptsReturn="True" MinHeight="68" MaxHeight="110" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="8" BorderBrush="{StaticResource BorderBrush}"/>
                <UniformGrid Columns="3" Margin="0,8,0,12">
                  <Button Click="SetTextAction_Click" Style="{StaticResource PrimaryButton}" Content="Set text"/>
                  <Button Click="TypeTextAction_Click" Content="Type keys"/>
                  <Button Click="GetTextAction_Click" Content="Get text" Margin="0"/>
                </UniformGrid>
                <TextBlock Style="{StaticResource SectionTitle}" Text="RESULT" Margin="0,0,0,5"/>
                <TextBox Text="{Binding AutomationOutput, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="88" MaxHeight="170" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="10.5" Background="#F7F8FA" BorderBrush="{StaticResource BorderBrush}" Padding="8"/>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem x:Name="RecordingTab" Header="  RECORDING  " Visibility="Collapsed">
            <Grid Margin="12">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="150"/>
              </Grid.RowDefinitions>

              <Border Background="#EEF5FA" CornerRadius="8" Padding="10">
                <StackPanel>
                  <TextBlock Text="JAVA RECORDING AND PLAYBACK" Foreground="#1F5E8C" FontSize="10" FontWeight="Bold"/>
                  <TextBlock Margin="0,4,0,0"
                             Text="This records Java/JAB automation intent and detailed element properties into a reusable locator repository for playback. It does not record video frames."
                             TextWrapping="Wrap"
                             FontSize="10.5"
                             Foreground="#37536B"/>
                </StackPanel>
              </Border>

              <Grid Grid.Row="1" Margin="0,10,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock Text="{Binding RecordingSessionName}" FontWeight="SemiBold" FontSize="12.5"/>
                  <TextBlock Text="{Binding RecordingStatus}" Foreground="{StaticResource MutedBrush}" FontSize="10.5" Margin="0,3,0,0" TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding RecordingProjectPath}" Foreground="#8A96A7" FontFamily="Consolas" FontSize="9.5" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                  <Button Click="StartRecordingSession_Click" Style="{StaticResource PrimaryButton}" Content="New session"/>
                  <Button Click="ToggleRecordingPause_Click" Content="Pause/Resume"/>
                  <Button Click="AddSelectedObject_Click" Content="Add selected object"/>
                  <Button Click="SaveRecording_Click" Content="Save project"/>
                  <Button Click="LoadRecording_Click" Content="Load project"/>
                  <Button Click="PlayRecording_Click" Content="Playback" Margin="0"/>
                </WrapPanel>
              </Grid>

              <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="10"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Padding="12,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                      <TextBlock Style="{StaticResource SectionTitle}" Text="OBJECT REPOSITORY"/>
                    </Border>
                    <ListBox Grid.Row="1" ItemsSource="{Binding RepositoryEntries}" SelectedItem="{Binding SelectedRepositoryEntry}" BorderThickness="0" Background="Transparent" Padding="8">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="11.5" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Description, StringFormat=Desc: {0}}" Foreground="{StaticResource MutedBrush}" FontSize="9.5" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding VirtualAccessibleName, StringFormat=JAWS: {0}}" Foreground="{StaticResource MutedBrush}" FontSize="9.5" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Path}" Foreground="{StaticResource MutedBrush}" FontFamily="Consolas" FontSize="9.5" TextWrapping="Wrap"/>
                          </StackPanel>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Padding="12,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                      <TextBlock Style="{StaticResource SectionTitle}" Text="RECORDED STEPS"/>
                    </Border>
                    <ListBox Grid.Row="1" ItemsSource="{Binding RecordedSteps}" SelectedItem="{Binding SelectedRecordedStep}" BorderThickness="0" Background="Transparent" Padding="8">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="11.5" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ObjectDescription, StringFormat=Desc: {0}}" Foreground="{StaticResource MutedBrush}" FontSize="9.5" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ObjectVirtualAccessibleName, StringFormat=JAWS: {0}}" Foreground="{StaticResource MutedBrush}" FontSize="9.5" TextWrapping="Wrap"/>
                            <TextBlock Foreground="{StaticResource MutedBrush}" FontFamily="Consolas" FontSize="9.5">
                              <Run Text="{Binding CapturedAtUtc, StringFormat={}{0:HH:mm:ss}}"/>
                              <Run Text="  ·  "/>
                              <Run Text="{Binding StepName}"/>
                              <Run Text="  Depth="/>
                              <Run Text="{Binding ObjectDepth}"/>
                            </TextBlock>
                          </StackPanel>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </Grid>
                </Border>
              </Grid>

              <Grid Grid.Row="3" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="10"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="10"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                  <Grid Margin="10">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="REPOSITORY PREVIEW"/>
                    <TextBox Grid.Row="1" Margin="0,8,0,0" Text="{Binding RecordingRepositoryPreview, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="10.5" Background="#F7F8FA" BorderBrush="{StaticResource BorderBrush}" Padding="8"/>
                  </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                  <Grid Margin="10">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="STEP PREVIEW"/>
                    <TextBox Grid.Row="1" Margin="0,8,0,0" Text="{Binding RecordingStepPreview, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="10.5" Background="#F7F8FA" BorderBrush="{StaticResource BorderBrush}" Padding="8"/>
                  </Grid>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource PanelBorder}">
                  <Grid Margin="10">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="PLAYBACK OUTPUT"/>
                    <TextBox Grid.Row="1" Margin="0,8,0,0" Text="{Binding PlaybackOutput, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="10.5" Background="#F7F8FA" BorderBrush="{StaticResource BorderBrush}" Padding="8"/>
                  </Grid>
                </Border>
              </Grid>
            </Grid>
          </TabItem>

          <TabItem x:Name="SettingsTab" Header="  SETTINGS  ">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="14">
                <Border Background="#F4F8FB" CornerRadius="8" Padding="10" Margin="0,0,0,12">
                  <StackPanel>
                    <TextBlock Text="JAVA ACCESS BRIDGE REQUIREMENTS" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SettingsSummary}" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,0" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>

                <TextBlock Style="{StaticResource SectionTitle}" Text="ACTIONS" Margin="0,0,0,6"/>
                <WrapPanel Margin="0,0,0,12">
                  <Button Command="{Binding RefreshRequirementsCommand}" Content="Refresh checks"/>
                  <Button Command="{Binding EnableJavaAccessBridgeCommand}" Style="{StaticResource PrimaryButton}" Content="Enable JAB"/>
                  <Button Command="{Binding DisableJavaAccessBridgeCommand}" Content="Disable JAB"/>
                  <Button Command="{Binding OpenEaseOfAccessCommand}" Content="Open Windows accessibility" Margin="0"/>
                </WrapPanel>

                <Border Background="#FFF9EC" CornerRadius="8" Padding="10" Margin="0,0,0,12">
                  <TextBlock Text="{Binding SettingsActionResult}" Foreground="#8A6522" FontSize="10.5" TextWrapping="Wrap"/>
                </Border>

                <TextBlock Style="{StaticResource SectionTitle}" Text="CHECKS" Margin="0,0,0,6"/>
                <ItemsControl ItemsSource="{Binding RequirementChecks}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="11.5"/>
                            <TextBlock Text="{Binding Details}" Foreground="{StaticResource MutedBrush}" FontSize="10.5" Margin="0,4,0,0" TextWrapping="Wrap"/>
                          </StackPanel>
                          <Border Grid.Column="1" Background="{Binding StatusBrush}" CornerRadius="10" Padding="8,3" Margin="10,0,0,0" VerticalAlignment="Top">
                            <TextBlock Text="{Binding Status}" Foreground="{Binding StatusForeground}" FontSize="10" FontWeight="SemiBold"/>
                          </Border>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,8" Background="{StaticResource BorderBrush}"/>
                <TextBlock Style="{StaticResource SectionTitle}" Text="DETECTED PATHS" Margin="0,0,0,6"/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                  </Grid.RowDefinitions>
                  <TextBlock Style="{StaticResource PropertyLabel}" Text="jabswitch"/>
                  <TextBlock Grid.Column="1" Style="{StaticResource PropertyValue}" Text="{Binding JabSwitchPath}"/>
                  <TextBlock Grid.Row="1" Style="{StaticResource PropertyLabel}" Text="Bridge DLL"/>
                  <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource PropertyValue}" Text="{Binding BridgeDllPath}"/>
                  <TextBlock Grid.Row="2" Style="{StaticResource PropertyLabel}" Text="JAVA_HOME"/>
                  <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource PropertyValue}" Text="{Binding JavaHomePath}"/>
                  <TextBlock Grid.Row="3" Style="{StaticResource PropertyLabel}" Text="AT key"/>
                  <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource PropertyValue}" Text="{Binding AccessibilityRegistrationPath}"/>
                </Grid>
              </StackPanel>
            </ScrollViewer>
          </TabItem>
        </TabControl>
      </Border>
    </Grid>
      </TabItem>

      <TabItem x:Name="RecorderWorkspaceTab" Header="  RECORDER  ">
        <Grid Margin="2">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="118"/>
          </Grid.RowDefinitions>

          <Border Grid.Row="0" Background="#1E293B" BorderBrush="#0F172A" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{Binding RecordingSessionName}" Foreground="White" FontWeight="SemiBold" FontSize="12.5" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding RecordingStatus}" Foreground="#CBD5E1" FontSize="10.5" Margin="0,3,0,0" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding RecordingProjectPath}" Foreground="#94A3B8" FontFamily="Consolas" FontSize="9.5" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                <Button Click="StartRecordingSession_Click" Style="{StaticResource ToolPrimaryButton}" ToolTip="Start new recording">
                  <TextBlock Text="●"/>
                </Button>
                <Button Click="AppendRecordingSession_Click" Style="{StaticResource ToolButton}" ToolTip="Add steps to current recording">
                  <TextBlock Text="+"/>
                </Button>
                <Button Click="PlayRecording_Click" Style="{StaticResource ToolButton}" ToolTip="Playback recorded steps">
                  <TextBlock Text="▶"/>
                </Button>
                <Button Click="GenerateJavaCode_Click" Style="{StaticResource ToolButton}" ToolTip="Generate Java code from recorded steps">
                  <Path Width="15" Height="15" Fill="#2563EB" Stretch="Uniform" Data="M8.7,16.3 4.4,12 8.7,7.7 7.3,6.3 1.6,12 7.3,17.7z M15.3,16.3 19.6,12 15.3,7.7 16.7,6.3 22.4,12 16.7,17.7z M13.1,4.4 9.1,20 10.9,20.5 14.9,4.9z"/>
                </Button>
                <Button Click="RecorderMoreActions_Click" Style="{StaticResource ToolButton}" ToolTip="More recording actions" Margin="0">
                  <Button.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Add selected object" Click="AddSelectedObject_Click"/>
                      <MenuItem Header="Save project as..." Click="SaveRecording_Click"/>
                      <MenuItem Header="Load project" Click="LoadRecording_Click"/>
                    </ContextMenu>
                  </Button.ContextMenu>
                  <TextBlock Text="⋯"/>
                </Button>
              </StackPanel>
            </Grid>
          </Border>

          <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="300" MinWidth="240"/>
              <ColumnDefinition Width="6"/>
              <ColumnDefinition Width="*" MinWidth="360"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Padding="8,6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                  <Grid>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="OBJECT REPOSITORY" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                      <Button Click="AddSelectedObject_Click" Style="{StaticResource ToolButton}" ToolTip="Add selected inspected element">
                        <TextBlock Text="+"/>
                      </Button>
                      <Button Click="RecorderDeleteRepositoryObject_Click" Style="{StaticResource ToolButton}" ToolTip="Delete selected repository object" Margin="0">
                        <TextBlock Text="×"/>
                      </Button>
                    </StackPanel>
                  </Grid>
                </Border>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding RepositoryEntries}"
                         SelectedItem="{Binding SelectedRepositoryEntry}"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="6"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Padding="6" BorderBrush="#E3E8EF" BorderThickness="0,0,0,1">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <StackPanel>
                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Description, StringFormat=Desc: {0}}" Foreground="{StaticResource MutedBrush}" FontSize="9.5" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Path}" Foreground="#8A96A7" FontFamily="Consolas" FontSize="9.5" TextTrimming="CharacterEllipsis"/>
                          </StackPanel>
                          <Button Grid.Column="1"
                                  Click="RecorderRepositoryDetails_Click"
                                  Style="{StaticResource ToolButton}"
                                  ToolTip="Show repository locator details"
                                  Margin="8,0,0,0">
                            <TextBlock Text="i"/>
                          </Button>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" Background="Transparent" HorizontalAlignment="Stretch"/>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Padding="8,6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                  <Grid>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="RECORDED TIMELINE" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" Click="RecorderDeleteStep_Click" Style="{StaticResource ToolButton}" ToolTip="Delete selected step" Margin="0">
                      <TextBlock Text="×"/>
                    </Button>
                  </Grid>
                </Border>
                <ListBox x:Name="RecorderStepsList"
                         Grid.Row="1"
                         ItemsSource="{Binding RecordedSteps}"
                         SelectedItem="{Binding SelectedRecordedStep}"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="6"
                         AllowDrop="True"
                         PreviewMouseLeftButtonDown="RecorderStepsList_PreviewMouseLeftButtonDown"
                         MouseMove="RecorderStepsList_MouseMove"
                         DragOver="RecorderStepsList_DragOver"
                         Drop="RecorderStepsList_Drop"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Padding="8" BorderBrush="#E3E8EF" BorderThickness="0,0,0,1">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <Border Width="24" Height="24" CornerRadius="12" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" VerticalAlignment="Top">
                            <TextBlock Text="{Binding Sequence}" Foreground="#2563EB" FontWeight="SemiBold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Border>
                          <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="11.5" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ObjectDescription, StringFormat=Desc: {0}}" Foreground="{StaticResource MutedBrush}" FontSize="9.5" TextWrapping="Wrap"/>
                            <TextBlock Foreground="#8A96A7" FontSize="9.5" Margin="0,3,0,0">
                              <Run Text="{Binding CapturedAtUtc, StringFormat={}{0:HH:mm:ss}}"/>
                              <Run Text=" | "/>
                              <Run Text="{Binding WindowTitle}"/>
                              <Run Text=" | depth "/>
                              <Run Text="{Binding ObjectDepth}"/>
                            </TextBlock>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#EFF6FF" BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="10" Padding="8,3" Margin="8,0,0,0" VerticalAlignment="Top">
                            <TextBlock Text="{Binding ActionKind}" Foreground="#2563EB" FontSize="9.5" FontWeight="SemiBold"/>
                          </Border>
                          <Button Grid.Column="3" Click="RecorderHighlightRecordedStep_Click" Style="{StaticResource ToolButton}" ToolTip="Highlight recorded element" Margin="8,0,0,0">
                            <TextBlock Text="◎"/>
                          </Button>
                          <Button Grid.Column="4" Click="RecorderStepDetails_Click" Style="{StaticResource ToolButton}" ToolTip="Show step locator details" Margin="4,0,0,0">
                            <TextBlock Text="i"/>
                          </Button>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>
          </Grid>

          <Border Grid.Row="2" Margin="0,8,0,0" Style="{StaticResource PanelBorder}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <Border Padding="8,5" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <TextBlock Style="{StaticResource SectionTitle}" Text="PLAYBACK CONSOLE"/>
              </Border>
              <TextBox Grid.Row="1"
                       Text="{Binding PlaybackOutput, Mode=OneWay}"
                       IsReadOnly="True"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Auto"
                       FontFamily="Consolas"
                       FontSize="10.5"
                       Background="#FBFCFE"
                       Foreground="#475467"
                       BorderThickness="0"
                       Padding="8"/>
            </Grid>
          </Border>
        </Grid>
      </TabItem>
    </TabControl>

    <Border x:Name="DiagnosticsPanel" Grid.Row="2" Margin="12,0,12,8" Style="{StaticResource PanelBorder}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="34"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Padding="12,5" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
          <Grid>
            <StackPanel Orientation="Horizontal">
              <Ellipse Width="7" Height="7" Fill="#33A06F" Margin="0,0,8,0"/>
              <TextBlock Style="{StaticResource SectionTitle}" Text="DIAGNOSTICS CONSOLE" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="9.5" Text="Native calls · discovery · crawl events" VerticalAlignment="Center" Margin="0,0,10,0"/>
              <Button Click="CopyLogs_Click" Content="Copy logs" Padding="9,4" Margin="0" FontSize="10.5"/>
            </StackPanel>
          </Grid>
        </Border>
        <ListBox x:Name="LogList" Grid.Row="1" ItemsSource="{Binding Logs}" BorderThickness="0" Background="#FBFCFE" FontFamily="Consolas" FontSize="10.5" Padding="6" Foreground="#475467" SelectionMode="Extended" KeyDown="LogList_KeyDown">
          <ListBox.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Copy selected logs" Click="CopySelectedLogs_Click" InputGestureText="Ctrl+C"/>
              <MenuItem Header="Copy all logs" Click="CopyAllLogs_Click"/>
            </ContextMenu>
          </ListBox.ContextMenu>
        </ListBox>
      </Grid>
    </Border>

    <Border Grid.Row="3" Background="#182235" Padding="12,0">
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Ellipse Width="7" Height="7" Fill="#55D79A"/>
          <TextBlock Text="{Binding Status}" Foreground="#E8ECF4" FontSize="10.5" Margin="8,0,0,0"/>
        </StackPanel>
        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#9CA7B8" FontSize="9.5" Text="x64  ·  WindowsAccessBridge-64.dll  ·  Inspect + Automate"/>
      </Grid>
    </Border>
  </Grid>
</Window>
