<Window x:Class="JabInspector.App.JavaCodePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generated Java Code"
        Width="900"
        Height="640"
        MinWidth="620"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC"
        FontFamily="Segoe UI">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Background="#0F172A" CornerRadius="10" Padding="12" Margin="0,0,0,10">
      <Grid>
        <StackPanel Margin="0,0,150,0">
          <TextBlock Text="Generated Java Code" Foreground="White" FontWeight="Bold" FontSize="14"/>
          <TextBlock Text="Repository-backed Java client main class" Foreground="#94A3B8" FontSize="11" Margin="0,3,0,0"/>
        </StackPanel>
        <Button Click="Copy_Click"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Padding="12,6"
                MinHeight="30"
                Background="#1E293B"
                BorderBrush="#475569"
                Foreground="White"
                ToolTip="Copy generated Java code">
          <StackPanel Orientation="Horizontal">
            <Path Width="13" Height="13" Fill="White" Stretch="Uniform" Data="M16,1H4C2.9,1,2,1.9,2,3v12h2V3h12V1z M19,5H8C6.9,5,6,5.9,6,7v14c0,1.1,0.9,2,2,2h11c1.1,0,2-0.9,2-2V7C21,5.9,20.1,5,19,5z"/>
            <TextBlock Text="Copy" Margin="7,0,0,0"/>
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <TextBox x:Name="CodeText"
             Grid.Row="1"
             IsReadOnly="True"
             AcceptsReturn="True"
             TextWrapping="NoWrap"
             VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Auto"
             FontFamily="Consolas"
             FontSize="12"
             Background="#0B1120"
             Foreground="#D1FAE5"
             BorderBrush="#334155"
             Padding="12"/>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Width="88" Content="Close" IsDefault="True" Click="Close_Click"/>
    </StackPanel>
  </Grid>
</Window>
