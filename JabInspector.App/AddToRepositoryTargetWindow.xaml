<Window x:Class="JabInspector.App.AddToRepositoryTargetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add to Object Repository"
        Width="460"
        Height="260"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBrush}"
        FontFamily="Segoe UI">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock Text="Add inspected element to repository" FontWeight="Bold" FontSize="15"/>
      <TextBlock Text="Choose where this selected Java element should be saved."
                 Foreground="{StaticResource MutedBrush}"
                 TextWrapping="Wrap"
                 Margin="0,4,0,0"/>
    </StackPanel>

    <StackPanel Grid.Row="1" Margin="0,18,0,0">
      <Button Click="Current_Click" HorizontalContentAlignment="Left" Margin="0,0,0,8" Padding="12,9">
        <StackPanel>
          <TextBlock Text="Use current repository" FontWeight="SemiBold"/>
          <TextBlock Text="Add to the repository currently loaded in the inspector." Foreground="{StaticResource MutedBrush}" FontSize="10.5"/>
        </StackPanel>
      </Button>
      <Button Click="Existing_Click" HorizontalContentAlignment="Left" Margin="0,0,0,8" Padding="12,9">
        <StackPanel>
          <TextBlock Text="Choose existing repository file" FontWeight="SemiBold"/>
          <TextBlock Text="Add directly into an existing .jrecording.json file." Foreground="{StaticResource MutedBrush}" FontSize="10.5"/>
        </StackPanel>
      </Button>
      <Button Click="New_Click" HorizontalContentAlignment="Left" Padding="12,9">
        <StackPanel>
          <TextBlock Text="Create new repository file" FontWeight="SemiBold"/>
          <TextBlock Text="Create a new .jrecording.json containing this object." Foreground="{StaticResource MutedBrush}" FontSize="10.5"/>
        </StackPanel>
      </Button>
    </StackPanel>

    <Button Grid.Row="2" Content="Cancel" Width="90" HorizontalAlignment="Right" Click="Cancel_Click"/>
  </Grid>
</Window>
