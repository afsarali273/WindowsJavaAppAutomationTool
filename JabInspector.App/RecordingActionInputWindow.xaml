<Window x:Class="JabInspector.App.RecordingActionInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recorder Action"
        Width="420"
        Height="220"
        MinWidth="360"
        MinHeight="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">
  <Border Padding="18">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <TextBlock x:Name="TitleBlock" Text="Action input" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"/>
      <TextBlock x:Name="DescriptionBlock" Grid.Row="1" Margin="0,6,0,12" Text="Provide the text to use for the recorded action." Foreground="#475569" TextWrapping="Wrap"/>

      <TextBox x:Name="ValueTextBox"
               Grid.Row="2"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               VerticalScrollBarVisibility="Auto"
               Padding="10"
               MinHeight="84"
               BorderBrush="#CBD5E1"
               Background="White"/>

      <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
        <Button Content="Cancel" Width="88" Height="32" Margin="0,0,8,0" Click="Cancel_Click"/>
        <Button Content="Record" Width="88" Height="32" Background="#2563EB" Foreground="White" BorderBrush="#2563EB" Click="Confirm_Click"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
