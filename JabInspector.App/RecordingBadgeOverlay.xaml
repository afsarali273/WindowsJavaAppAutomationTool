<Window x:Class="JabInspector.App.RecordingBadgeOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="330"
        Height="64"
        MinWidth="280"
        MinHeight="56"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        AllowsTransparency="True"
        ShowActivated="False">
  <Grid>
    <Border Background="#E6111827"
            BorderBrush="#334155"
            BorderThickness="1"
            CornerRadius="14"
            Padding="8,6"
            SnapsToDevicePixels="True"
            MouseLeftButtonDown="BadgeSurface_MouseLeftButtonDown">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Border Width="32" Height="32" CornerRadius="16" Background="#7F1D1D" VerticalAlignment="Center">
          <Grid>
            <Ellipse Width="11" Height="11" Fill="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Grid>
        </Border>

        <StackPanel Grid.Column="1" Margin="8,0,8,0" VerticalAlignment="Center">
          <TextBlock x:Name="LiveText" Text="RECORDING" Foreground="White" FontWeight="SemiBold" FontSize="11.5"/>
          <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
            <TextBlock x:Name="BadgeTextBlock" Text="0" Foreground="#93C5FD" FontSize="11.5" FontWeight="SemiBold"/>
            <TextBlock Text=" steps" Foreground="#CBD5E1" FontSize="11"/>
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <Button x:Name="ActionsButton"
                  Click="ActionsButton_Click"
                  Width="32"
                  Height="32"
                  Margin="0,0,6,0"
                  Padding="0"
                  ToolTip="Recording actions"
                  Background="#1F2937"
                  BorderBrush="#475569"
                  BorderThickness="1">
            <Viewbox Width="14" Height="14">
              <Canvas Width="24" Height="24">
                <Path Fill="#F8FAFC" Data="M13,3L4,14h6l-1,7 9-11h-6l1-7z"/>
              </Canvas>
            </Viewbox>
          </Button>

          <Button x:Name="PauseButton"
                  Click="PauseButton_Click"
                  Width="32"
                  Height="32"
                  Margin="0,0,6,0"
                  Padding="0"
                  ToolTip="Pause or resume recording"
                  Background="#1F2937"
                  BorderBrush="#475569"
                  BorderThickness="1"
                  Foreground="White">
            <Viewbox Width="14" Height="14">
              <Canvas Width="24" Height="24">
                <Rectangle x:Name="PauseLeftBar" Canvas.Left="7" Canvas.Top="5" Width="3.5" Height="14" Fill="White"/>
                <Rectangle x:Name="PauseRightBar" Canvas.Left="13.5" Canvas.Top="5" Width="3.5" Height="14" Fill="White"/>
                <Path x:Name="ResumeTriangle" Visibility="Collapsed" Fill="White" Data="M8,5 L19,12 L8,19 Z"/>
              </Canvas>
            </Viewbox>
          </Button>

          <Button Click="StopButton_Click"
                Width="32"
                Height="32"
                Margin="0,0,6,0"
                  Padding="0"
                  ToolTip="Stop recording"
                  Background="#DC2626"
                  BorderBrush="#EF4444"
                  BorderThickness="1">
            <Rectangle Width="10" Height="10" RadiusX="1.5" RadiusY="1.5" Fill="White"/>
          </Button>

          <Button Click="StudioButton_Click"
                Width="32"
                Height="32"
                  Padding="0"
                  ToolTip="Open recorder studio"
                  Background="#1F2937"
                  BorderBrush="#475569"
                  BorderThickness="1">
            <Viewbox Width="14" Height="14">
              <Canvas Width="24" Height="24">
                <Rectangle Canvas.Left="5" Canvas.Top="5" Width="14" Height="14" RadiusX="2" RadiusY="2" Stroke="White" StrokeThickness="2"/>
                <Line X1="8" Y1="10" X2="16" Y2="10" Stroke="White" StrokeThickness="2"/>
                <Line X1="8" Y1="14" X2="14" Y2="14" Stroke="White" StrokeThickness="2"/>
              </Canvas>
            </Viewbox>
          </Button>
        </StackPanel>
      </Grid>
    </Border>
    <Popup x:Name="ActionsPopup"
           PlacementTarget="{Binding ElementName=ActionsButton}"
           Placement="Bottom"
           HorizontalOffset="-6"
           VerticalOffset="6"
           StaysOpen="False"
           AllowsTransparency="True"
           PopupAnimation="Fade">
      <Border Background="#F8FAFC"
              BorderBrush="#CBD5E1"
              BorderThickness="1"
              CornerRadius="10"
              Padding="6"
              MinWidth="180"
              SnapsToDevicePixels="True">
        <StackPanel>
          <Button Click="ActionFocus_Click" Style="{x:Null}" Padding="8,6" Margin="0,0,0,2" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0">
            <StackPanel Orientation="Horizontal">
              <Path Width="12" Height="12" Fill="#0F766E" Stretch="Uniform" Data="M4,4h5V2H4C2.9,2,2,2.9,2,4v5h2V4z M20,2h-5v2h5v5h2V4C22,2.9,21.1,2,20,2z M12,8a4,4,0,1,0,4,4A4,4,0,0,0,12,8Z"/>
              <TextBlock Text="Focus" Margin="8,0,0,0" Foreground="#0F172A" FontSize="12"/>
            </StackPanel>
          </Button>
          <Button Click="ActionClick_Click" Style="{x:Null}" Padding="8,6" Margin="0,0,0,2" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0">
            <StackPanel Orientation="Horizontal">
              <Path Width="12" Height="12" Fill="#2563EB" Stretch="Uniform" Data="M11.5,14.5l-2.43-4.14l4.24-1.72L5.5,5l2.42,10.64l2.12-3.69L11.5,14.5z"/>
              <TextBlock Text="Click" Margin="8,0,0,0" Foreground="#0F172A" FontSize="12"/>
            </StackPanel>
          </Button>
          <Button Click="ActionDoubleClick_Click" Style="{x:Null}" Padding="8,6" Margin="0,0,0,2" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0">
            <StackPanel Orientation="Horizontal">
              <Path Width="12" Height="12" Fill="#2563EB" Stretch="Uniform" Data="M11.5,14.5l-2.43-4.14l4.24-1.72L5.5,5l2.42,10.64l2.12-3.69L11.5,14.5z M16.5,12l-1.5-.75V7h-3"/>
              <TextBlock Text="Double-click" Margin="8,0,0,0" Foreground="#0F172A" FontSize="12"/>
            </StackPanel>
          </Button>
          <Button Click="ActionSetText_Click" Style="{x:Null}" Padding="8,6" Margin="0,0,0,2" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0">
            <StackPanel Orientation="Horizontal">
              <Path Width="12" Height="12" Fill="#7C3AED" Stretch="Uniform" Data="M21,11H3V9h18V11z M21,15H3v-2h18V15z M21,7H3V5h18V7z"/>
              <TextBlock Text="Set text" Margin="8,0,0,0" Foreground="#0F172A" FontSize="12"/>
            </StackPanel>
          </Button>
          <Button Click="ActionTypeText_Click" Style="{x:Null}" Padding="8,6" Margin="0,0,0,2" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0">
            <StackPanel Orientation="Horizontal">
              <Path Width="12" Height="12" Fill="#7C3AED" Stretch="Uniform" Data="M20,5H4C2.9,5,2,5.9,2,7v10c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V7C22,5.9,21.1,5,20,5z M20,17H4V7h16V17z M5,9h2v2H5V9z"/>
              <TextBlock Text="Type text" Margin="8,0,0,0" Foreground="#0F172A" FontSize="12"/>
            </StackPanel>
          </Button>
          <Button Click="ActionGetText_Click" Style="{x:Null}" Padding="8,6" Margin="0,0,0,2" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0">
            <StackPanel Orientation="Horizontal">
              <Path Width="12" Height="12" Fill="#0D9488" Stretch="Uniform" Data="M14,2H6C4.9,2,4,2.9,4,4v16c0,1.1,0.89,2,1.99,2H18c1.1,0,2-0.9,2-2V8L14,2z M12,18H8v-2h4V18z"/>
              <TextBlock Text="Get text" Margin="8,0,0,0" Foreground="#0F172A" FontSize="12"/>
            </StackPanel>
          </Button>
          <Button Click="ActionAssertVisible_Click" Style="{x:Null}" Padding="8,6" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0">
            <StackPanel Orientation="Horizontal">
              <Path Width="12" Height="12" Fill="#D97706" Stretch="Uniform" Data="M12,5A9,9 0 0,0 3,12A9,9 0 0,0 12,19A9,9 0 0,0 21,12A9,9 0 0,0 12,5M12,9A3,3 0 0,1 15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9Z"/>
              <TextBlock Text="Assert visible" Margin="8,0,0,0" Foreground="#0F172A" FontSize="12"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>
    </Popup>
  </Grid>
</Window>
