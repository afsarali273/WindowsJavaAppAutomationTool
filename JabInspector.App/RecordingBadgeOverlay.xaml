<Window x:Class="JabInspector.App.RecordingBadgeOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460"
        Height="92"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#111827"
        ShowActivated="False">
  <Border Background="#111827" BorderBrush="#334155" BorderThickness="1" Padding="12" MouseLeftButtonDown="BadgeSurface_MouseLeftButtonDown">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Border Width="50" Height="50" CornerRadius="25" Background="#7F1D1D" VerticalAlignment="Center">
        <Grid>
          <Ellipse Width="20" Height="20" Fill="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
      </Border>

      <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
        <TextBlock x:Name="LiveText" Text="RECORDING" Foreground="White" FontWeight="Bold" FontSize="14"/>
        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
          <TextBlock x:Name="BadgeTextBlock" Text="0" Foreground="#93C5FD" FontSize="13" FontWeight="SemiBold"/>
          <TextBlock Text=" step(s) captured" Foreground="#CBD5E1" FontSize="13"/>
        </StackPanel>
      </StackPanel>

      <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
        <Button x:Name="PauseButton"
                Click="PauseButton_Click"
                Width="50"
                Height="44"
                Margin="0,0,8,0"
                Padding="0"
                ToolTip="Pause or resume recording"
                Background="#1F2937"
                BorderBrush="#475569"
                Foreground="White">
          <Viewbox Width="20" Height="20">
            <Canvas Width="24" Height="24">
              <Rectangle x:Name="PauseLeftBar" Canvas.Left="7" Canvas.Top="5" Width="3.5" Height="14" Fill="White"/>
              <Rectangle x:Name="PauseRightBar" Canvas.Left="13.5" Canvas.Top="5" Width="3.5" Height="14" Fill="White"/>
              <Path x:Name="ResumeTriangle" Visibility="Collapsed" Fill="White" Data="M8,5 L19,12 L8,19 Z"/>
            </Canvas>
          </Viewbox>
        </Button>

        <Button Click="StopButton_Click"
              Width="50"
              Height="44"
              Margin="0,0,8,0"
                Padding="0"
                ToolTip="Stop recording"
                Background="#DC2626"
                BorderBrush="#EF4444">
            <Rectangle Width="16" Height="16" RadiusX="2" RadiusY="2" Fill="White"/>
        </Button>

        <Button Click="StudioButton_Click"
              Width="50"
              Height="44"
                Padding="0"
                ToolTip="Open recorder studio"
                Background="#1F2937"
                BorderBrush="#475569">
            <Viewbox Width="20" Height="20">
            <Canvas Width="24" Height="24">
              <Rectangle Canvas.Left="5" Canvas.Top="5" Width="14" Height="14" RadiusX="2" RadiusY="2" Stroke="White" StrokeThickness="2"/>
              <Line X1="8" Y1="10" X2="16" Y2="10" Stroke="White" StrokeThickness="2"/>
              <Line X1="8" Y1="14" X2="14" Y2="14" Stroke="White" StrokeThickness="2"/>
            </Canvas>
          </Viewbox>
        </Button>
      </StackPanel>
    </Grid>
  </Border>
</Window>
