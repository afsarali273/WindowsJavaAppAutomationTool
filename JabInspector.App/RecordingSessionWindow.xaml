<Window x:Class="JabInspector.App.RecordingSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Start Java Recording"
        Width="460"
        Height="360"
        MinHeight="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F7F9FC"
        FontFamily="Segoe UI">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <ScrollViewer Grid.Row="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="True">
      <StackPanel Margin="0,0,6,0">
        <StackPanel>
          <TextBlock Text="Java Recording Session" FontSize="18" FontWeight="SemiBold"/>
          <TextBlock Margin="0,6,0,0"
                     Text="This records Java/JAB repository objects and automation steps for reliable playback. It does not capture video frames."
                     TextWrapping="Wrap"
                     Foreground="#667085"
                     FontSize="11"/>
        </StackPanel>

        <StackPanel Margin="0,18,0,0">
          <TextBlock Text="Session name" Margin="0,0,0,6"/>
          <TextBox x:Name="SessionNameBox" Padding="8" Text="JavaRecording"/>
        </StackPanel>

        <StackPanel Margin="0,14,0,0">
          <TextBlock Text="Application alias" Margin="0,0,0,6"/>
          <TextBox x:Name="ApplicationAliasBox" Padding="8"/>
        </StackPanel>

        <Border Margin="0,16,0,0" Padding="10" CornerRadius="8" Background="#EEF5FA">
          <TextBlock Text="Recommended flow: attach to the target Java window, start recording, then use the Automation tab so each step is captured with repository-backed locator details."
                     TextWrapping="Wrap"
                     Foreground="#1F5E8C"
                     FontSize="11"/>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Width="84" Margin="0,0,8,0" Content="Cancel" IsCancel="True"/>
      <Button Width="110" Content="Start recording" IsDefault="True" Click="StartRecording_Click"/>
    </StackPanel>
  </Grid>
</Window>
