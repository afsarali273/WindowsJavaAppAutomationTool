<Window x:Class="JabInspector.App.LocatorDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Locator Details"
        Width="760"
        Height="560"
        MinWidth="560"
        MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC"
        FontFamily="Segoe UI">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Background="#0F172A" CornerRadius="10" Padding="12" Margin="0,0,0,10">
      <Grid>
        <StackPanel>
          <TextBlock x:Name="TitleText" Text="Locator Details" Foreground="White" FontWeight="Bold" FontSize="14"/>
          <TextBlock x:Name="SubtitleText" Text="Playback metadata and locator properties" Foreground="#94A3B8" FontSize="11" Margin="0,3,0,0"/>
        </StackPanel>
        <Button HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Click="Copy_Click"
                Padding="10,5"
                MinHeight="28"
                Background="#1E293B"
                BorderBrush="#475569"
                Foreground="White"
                ToolTip="Copy details to clipboard">
          <StackPanel Orientation="Horizontal">
            <Path Width="12" Height="12" Fill="White" Stretch="Uniform" Data="M16,1H4C2.9,1,2,1.9,2,3v12h2V3h12V1z M19,5H8C6.9,5,6,5.9,6,7v14c0,1.1,0.9,2,2,2h11c1.1,0,2-0.9,2-2V7C21,5.9,20.1,5,19,5z"/>
            <TextBlock Text="Copy" Margin="6,0,0,0"/>
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <TextBox x:Name="DetailsText"
             Grid.Row="1"
             IsReadOnly="True"
             AcceptsReturn="True"
             TextWrapping="NoWrap"
             VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Auto"
             FontFamily="Consolas"
             FontSize="11"
             Background="#111827"
             Foreground="#67E8F9"
             BorderBrush="#334155"
             Padding="12"/>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Width="88" Content="Close" IsDefault="True" Click="Close_Click"/>
    </StackPanel>
  </Grid>
</Window>
